data/myshop.db
data/*.db
data/*.sqlite3

# Ignore SQLite connection object representations (if they somehow get created as files)
*<sqlite3.Connection object at 0x*.db
*<sqlite3.Connection object at 0x*.sqlite3
*<sqlite3.Connection object at 0x*.sqlitedb

